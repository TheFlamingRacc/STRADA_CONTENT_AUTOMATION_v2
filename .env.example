# ─── API ──────────────────────────────────────────────────────────────────────
BASE_URL=
ENV_URL=
AUTOMATION_KEY=

# Кілька ключів через кому
GEMINI_KEYS=key1,key2,key3

# YouTube Data API v3 (опціонально — якщо не вказано, відео не додаються)
YOUTUBE_API_KEY=

# ─── ЮЗЕРИ ────────────────────────────────────────────────────────────────────
# Весь масив users.json як один JSON-рядок (без переносів рядків)
# Приклад: [{"id":1,"username":"Victor","email":"...","password":"...","character_name":"Віктор","prompt":"..."}]
USERS_JSON=

# ─── РОЗКЛАД ──────────────────────────────────────────────────────────────────
POSTS_PER_DAY_MIN=18
POSTS_PER_DAY_MAX=22
ACTIVE_HOUR_START=8
ACTIVE_HOUR_END=23

# ─── КОНТЕНТ ──────────────────────────────────────────────────────────────────
MAX_NEW_ARTICLES=30
INVENTED_TOPIC_CHANCE=0.3
SHORT_POST_CHANCE=0.3
MEDIUM_POST_CHANCE=0.4
# long = 1 - short - medium = 0.3
YOUTUBE_IN_POST_CHANCE=0.4

# ─── ENGAGEMENT ───────────────────────────────────────────────────────────────
ENGAGEMENT_ENABLED=true
LIKES_PER_RUN=5
SAVE_CHANCE=0.3
ENGAGEMENT_DELAY_MIN_MS=3000
ENGAGEMENT_DELAY_MAX_MS=8000
# Cron: о 10, 14, 18, 21 годині за Києвом
ENGAGEMENT_CRON=0 10,14,18,21 * * *

# ─── STORIES ──────────────────────────────────────────────────────────────────
STORIES_ENABLED=true
STORIES_PER_DAY_MIN=2
STORIES_PER_DAY_MAX=5

# ─── DISCORD ──────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
# 'all' | 'error' | 'none' (дефолт: all)
DISCORD_LOG_LEVEL=all

# ─── ТЕСТОВИЙ РЕЖИМ ───────────────────────────────────────────────────────────
# Кількість постів за замовчуванням для: npm run test-publish
# Можна перевизначити аргументом: npm run test-publish -- 5
TEST_POSTS_COUNT=3

# ─── ШЛЯХИ ────────────────────────────────────────────────────────────────────
# Railway Volume — вкажи шлях де змонтований Volume
# DATA_DIR=/data
